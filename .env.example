# Conexión a MongoDB Atlas (o local: mongodb://127.0.0.1:27017/dnd)
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/dnd?retryWrites=true&w=majority

# Firma de los JWT (poné algo largo y aleatorio)
JWT_SECRET=cambiame-por-un-secreto-largo

# "Pepper" que se concatena a las passwords antes de hashear (dejá vacío si no querés)
SECRET=

# Puerto local (Vercel lo ignora)
PORT=4000
