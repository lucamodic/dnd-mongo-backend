{
  "name": "dnd-mongo-backend",
  "version": "1.0.0",
  "description": "Backend MongoDB (Express + Mongoose) para la app de D&D de principiantes.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed:users": "ts-node-dev --transpile-only src/seeders/seedUsers.ts",
    "import:races": "ts-node-dev --transpile-only src/scripts/importAll.ts races",
    "import:classes": "ts-node-dev --transpile-only src/scripts/importAll.ts classes",
    "import:spells": "ts-node-dev --transpile-only src/scripts/importAll.ts spells",
    "import:monsters": "ts-node-dev --transpile-only src/scripts/importAll.ts monsters",
    "import:all": "ts-node-dev --transpile-only src/scripts/importAll.ts all",
    "export:summary": "ts-node-dev --transpile-only src/scripts/exportSpellsForSummary.ts",
    "apply:summaries": "ts-node-dev --transpile-only src/scripts/applySpellSummaries.ts",
    "apply:monster-names": "ts-node-dev --transpile-only src/scripts/applyMonsterNames.ts",
    "apply:recommended": "ts-node-dev --transpile-only src/scripts/applyRecommendedSpells.ts",
    "apply:subclasses": "ts-node-dev --transpile-only src/scripts/applySubclasses.ts",
    "apply:custom-classes": "ts-node-dev --transpile-only src/scripts/applyCustomClasses.ts",
    "wikidot:build-spell-migration": "ts-node-dev --transpile-only src/scripts/buildWikidotSpellMigration.ts",
    "wikidot:curate-custom-draft": "ts-node-dev --transpile-only src/scripts/curateWikidotCustomSpellsDraft.ts",
    "wikidot:curate-higher-level-audit": "ts-node-dev --transpile-only src/scripts/curateHigherLevelAudit.ts",
    "wikidot:import-custom-spells": "ts-node-dev --transpile-only src/scripts/importCustomSpellsFromJson.ts",
    "wikidot:apply-higher-level": "ts-node-dev --transpile-only src/scripts/applyHigherLevelFromJson.ts",
    "wikidot:apply-attack-type": "ts-node-dev --transpile-only src/scripts/applyWikidotAttackType.ts",
    "smoke": "ts-node-dev --transpile-only test/smoke.ts"
  },
  "keywords": [
    "dnd",
    "mongodb",
    "express"
  ],
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "mongodb-memory-server": "^11.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
